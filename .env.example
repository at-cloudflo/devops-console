# ============================================================
# DevOps Console — Root Environment Example
# Used by Docker Compose. Copy to .env and adjust as needed.
# ============================================================

# Backend
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-long-random-secret
ALLOWED_ORIGINS=http://localhost:4200

# Frontend (used by Docker Compose build arg, if applicable)
FRONTEND_PORT=4200
