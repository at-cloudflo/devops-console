# ──────────────────────────────────────────────────────────────────────────────
# Private npm registry configuration — DevOps Console Frontend
#
# Copy this file to .npmrc and fill in your values.
# .npmrc is in .gitignore — never commit a file containing real tokens.
#
# In Azure DevOps pipelines, the npmAuthenticate@0 task writes .npmrc
# automatically — you do not need to create it manually on the agent.
# ──────────────────────────────────────────────────────────────────────────────

# ── Option A: Azure Artifacts feed ────────────────────────────────────────
# Replace <org>, <project>, and <feed> with your values.
# The token is written by the pipeline task, not stored here.
registry=https://pkgs.dev.azure.com/<org>/<project>/_packaging/<feed>/npm/registry/
always-auth=true
//pkgs.dev.azure.com/<org>/<project>/_packaging/<feed>/npm/registry/:_authToken=${AZURE_ARTIFACTS_TOKEN}

# ── Option B: Private Artifactory / Nexus / Verdaccio ─────────────────────
# registry=https://npm.your-company.com/
# //npm.your-company.com/:_authToken=${NPM_TOKEN}

# ── Scoped packages from a private registry ───────────────────────────────
# @your-scope:registry=https://pkgs.dev.azure.com/<org>/<project>/_packaging/<feed>/npm/registry/
# //pkgs.dev.azure.com/<org>/<project>/_packaging/<feed>/npm/registry/:_authToken=${AZURE_ARTIFACTS_TOKEN}
