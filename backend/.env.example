# Server
NODE_ENV=development
PORT=3000

# Session
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# CORS
ALLOWED_ORIGINS=http://localhost:4200

# Refresh intervals (milliseconds)
POOLS_REFRESH_MS=60000
AGENTS_REFRESH_MS=60000
QUEUE_REFRESH_MS=30000
APPROVALS_REFRESH_MS=30000
VERTEX_JOBS_REFRESH_MS=60000
ALERTS_REFRESH_MS=30000

# Alert thresholds
POOL_CRITICAL_THRESHOLD=50
POOL_WARNING_THRESHOLD=70
AGENT_OFFLINE_ALERT_MINUTES=30
QUEUE_WAIT_ALERT_MINUTES=60
APPROVAL_AGE_ALERT_HOURS=24

# ── Teams notifications ────────────────────────────────────────────────────
# Fallback webhook URL used when teamsNotifications.webhookUrl in config is empty.
# Full control (enable/disable, min severity, etc.) is in the app Config page.
# Teams channel → Manage channel → Connectors → Incoming Webhook → Create → copy URL here.
TEAMS_WEBHOOK_URL=

# ── MLOps data source flag ─────────────────────────────────────────────────
# Set to 'false' to switch MLOps from mock JSON to real Vertex AI API calls.
USE_MOCK_MLOPS=true

# ── Azure DevOps ───────────────────────────────────────────────────────────
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/ali0046
AZURE_DEVOPS_TOKEN=your-bearer-token-here
# Comma-separated project names to EXCLUDE from monitoring (all others are included automatically)
AZURE_DEVOPS_PROJECTS_EXCLUDE=Default
# Concurrency limits for parallel project queries (tune to avoid ADO rate limits)
ADO_QUEUE_CONCURRENCY=10
ADO_APPROVAL_CONCURRENCY=15

# ── Vertex AI / GCP (required when USE_MOCK_MLOPS=false) ───────────────────
# Comma-separated GCP project IDs (overrides GCP_PROJECT_ID if set)
GCP_PROJECTS=my-gcp-project-id
# Comma-separated regions to query (overrides GCP_REGION if set)
GCP_REGIONS=us-central1,europe-west4
# Local dev only — not needed on Cloud Run (Workload Identity is used automatically)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Legacy single-value vars (still supported, used as fallback)
GCP_PROJECT_ID=
GCP_REGION=

# Future: Entra ID (leave empty for POC)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
